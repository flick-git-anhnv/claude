{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(npm *)",
      "Bash(npx *)",
      "Bash(git *)",
      "Bash(python *)",
      "Bash(pip *)",
      "Bash(node *)",
      "Glob",
      "Grep",
      "Read",
      "WebSearch",
      "WebFetch",
      "Edit",
      "Write"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/config-protection.js"
          }
        ]
      }
    ]
  }
}
